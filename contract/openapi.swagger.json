    "/v1/auth/sessions/{sessionId}": {
      "delete": {
        "summary": "Revoke a specific session by ID.",
        "description": "Errors: UNAUTHENTICATED/invalid_token\n        NOT_FOUND/session_not_found\n        PERMISSION_DENIED/session_not_owned",
        "operationId": "SessionService_RevokeSession",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RevokeSessionResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "SessionService"
        ]
      }
    },
    "/v1/auth/verify/whatsapp": {
      "post": {
        "summary": "Generate a WhatsApp pre-filled verification link for phone OTP.",
        "description": "Errors: UNAUTHENTICATED/invalid_token\n        FAILED_PRECONDITION/phone_not_set",
        "operationId": "VerificationService_GetWhatsAppVerificationLink",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetWhatsAppVerificationLinkResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1GetWhatsAppVerificationLinkRequest"
            }
          }
        ],
        "tags": [
          "VerificationService"
        ]
      }
    }
  },
