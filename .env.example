# ─── Server ──────────────────────────────────────────────
GRPC_PORT=50051
HTTP_PORT=8080

# ─── PostgreSQL ──────────────────────────────────────────
CORE_AUTH_API_HOST=localhost
CORE_AUTH_API_PORT=5432
CORE_AUTH_API_USERNAME=core_auth
CORE_AUTH_API_PASSWORD=core_auth
CORE_AUTH_API_DBNAME=core_auth

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────
RSA_PRIVATE_KEY_PATH=keys/private.pem
JWT_ISSUER=core-auth

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000

# MFA
MFA_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxx

WHATSAPP_BUSINESS_PHONE=+62813xxxxxxxxxxx

# ─── OAuth2 (Google) ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
